enum Plan {
  free
  growth
  pro
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id
  email     String   @unique
  shop      Shop?
  createdAt DateTime @default(now())
}

model Shop {
  id             String    @id @default(cuid())
  ownerId        String    @unique
  owner          User      @relation(fields: [ownerId], references: [id])
  shopName       String
  slug           String    @unique
  whatsappNumber String
  description    String    @default("")
  logoUrl        String    @default("")
  products       Product[]
  orders         Order[]   // ← add this relation

  plan             Plan      @default(free)
  planActivatedAt  DateTime?
  lastPaystackRef  String?

  isActive       Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id     String @id @default(cuid())
  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id], onDelete: Cascade)

  // Snapshot of items at order time — not a relation to Product,
  // since products can change price/name/be deleted after the order is placed.
  items Json

  customerName    String
  customerPhone   String
  customerAddress String

  total     Int
  createdAt DateTime @default(now())
}

model Product {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name      String
  price     Int
  imageUrl  String   @default("")
  available Boolean  @default(true)
  stock     Int?
  createdAt DateTime @default(now())
}